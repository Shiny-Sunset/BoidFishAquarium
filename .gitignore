# ========================================
# Unity .gitignore
# ========================================

# Unity generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# User-specific settings
/[Uu]serSettings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Crash Reports
sysinfo.txt
crashlytics-build.properties

# Build outputs (WebGL is served from /docs/ instead)
/[Bb]uild/
/[Bb]uild_[Ww]in/

# ========================================
# IDE / Editor
# ========================================

# Visual Studio
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# JetBrains Rider
.idea/
*.iml

# Visual Studio Code
.vscode/

# ========================================
# OS generated files
# ========================================

# Windows
[Tt]humbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# ========================================
# Unity specific
# ========================================

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Compressed archives (don't track zip files)
*.zip
*.7z
*.rar
*.tar.gz

# Burst debug information
*_BurstDebugInformation_DoNotShip/

# Plastic SCM
*.ignore
*.private
*.private.meta

# Fonts
*SDF.asset

# TextMesh Pro
/[Aa]ssets/TextMesh Pro/

# Gradle (Android builds)
/*.gradle
.gradle/
